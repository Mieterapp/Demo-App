{
  "expo": {
    "name": "Demo-App",
    "slug": "Demo-App",
    "version": "1.0.0",
    "scheme": "demoapp",
    "privacy": "unlisted",
    "orientation": "portrait",
    "backgroundColor": "#ffffff",
    "icon": "./assets/DemoLogoIcon.png",
    "splash": {
      "image": "./assets/LogoDATASECImmobilienAG.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.demoapp-datasec.test",
      "infoPlist": {
      },
      "buildNumber": "150000004"
    },
    "android": {
      "package": "com.demoapp.app",
      "versionCode": 150000000,
      "permissions": ["NOTIFICATIONS"],
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoDATASECImmobilienAG.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters":  [{
        "autoVerify": true,
        "action": "VIEW",
        "data": {
          "scheme": "https",
          "host": "de.demoapp-datasec.test"
        },
        "category": ["BROWSABLE", "DEFAULT"]
      }]
    },
    "androidNavigationBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "iosDisplayInForeground": true,
      "icon": "./assets/LogoDATASECImmobilienAG.png",
      "color": "#005ca9",
      "androidMode": "default"
    },
    "hooks": {
      "postPublish": [
      ]
    }
  }
}
